<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Key của bạn - ZedPing</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Sora:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #0f1117;
      --surface: #181c27;
      --border:  #2a2f3e;
      --accent:  #4f9eff;
      --accent2: #7c3aed;
      --text:    #e8eaf0;
      --muted:   #6b7280;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Sora', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(79,158,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(79,158,255,.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 40px 36px;
      width: 100%;
      max-width: 420px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent2), var(--accent));
    }

    .logo {
      font-family: 'JetBrains Mono', monospace;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 3px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 6px;
    }

    .subtitle {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 28px;
    }

    /* Loading */
    .loading {
      text-align: center;
      padding: 20px 0;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin .7s linear infinite;
      margin: 0 auto 12px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .loading p {
      color: var(--muted);
      font-size: 13px;
    }

    /* Error */
    .msg-error {
      background: rgba(239,68,68,.1);
      border: 1px solid rgba(239,68,68,.3);
      border-radius: 10px;
      padding: 16px;
      color: #fca5a5;
      font-size: 13px;
      text-align: center;
      display: none;
    }

    /* Key result */
    .key-result {
      display: none;
      background: rgba(34,197,94,.06);
      border: 1px solid rgba(34,197,94,.25);
      border-radius: 12px;
      padding: 20px;
    }

    .key-result-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #4ade80;
      margin-bottom: 10px;
    }

    .key-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      letter-spacing: 1px;
      word-break: break-all;
      margin-bottom: 16px;
    }

    .key-meta {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 16px;
    }

    .key-meta-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
    }

    .key-meta-row span:first-child { color: var(--muted); }
    .key-meta-row span:last-child  { color: #d1fae5; font-weight: 600; }

    .copy-btn {
      width: 100%;
      padding: 12px;
      background: rgba(34,197,94,.12);
      border: 1px solid rgba(34,197,94,.3);
      border-radius: 8px;
      color: #4ade80;
      font-family: 'Sora', sans-serif;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
    }

    .copy-btn:hover { background: rgba(34,197,94,.22); }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">Zed</div>
    <p class="subtitle">Key của bạn</p>

    <div class="loading" id="loading">
      <div class="spinner"></div>
      <p>Đang tải key...</p>
    </div>

    <div class="msg-error" id="errMsg"></div>

    <div class="key-result" id="result">
      <div class="key-result-label">✅ Key hợp lệ</div>
      <div class="key-value" id="r-key"></div>
      <div class="key-meta">
        <div class="key-meta-row">
          <span>Loại</span>
          <span id="r-type"></span>
        </div>
        <div class="key-meta-row">
          <span>Hết hạn lúc</span>
          <span id="r-expiry"></span>
        </div>
        <div class="key-meta-row">
          <span>Còn lại</span>
          <span id="r-timeleft"></span>
        </div>
      </div>
      <button class="copy-btn" onclick="copyKey()">📋 Sao chép Key</button>
    </div>
  </div>

  <script>
    // ← Đổi thành Worker URL của bạn
    const WORKER_URL = "https://YOUR_WORKER.workers.dev";

    const loading = document.getElementById("loading");
    const errMsg  = document.getElementById("errMsg");
    const result  = document.getElementById("result");

    function showError(text) {
      loading.style.display = "none";
      errMsg.textContent = text;
      errMsg.style.display = "block";
    }

    async function loadKey() {
      const params = new URLSearchParams(window.location.search);
      const key    = params.get("k");

      if (!key) {
        showError("❌ Không tìm thấy key. Vui lòng quay lại và hoàn thành quảng cáo!");
        return;
      }

      try {
        const res  = await fetch(`${WORKER_URL}/getkey?k=${encodeURIComponent(key)}`);
        const data = await res.json();

        loading.style.display = "none";

        if (data.success) {
          document.getElementById("r-key").textContent      = data.key;
          document.getElementById("r-type").textContent     = data.type === "NormalKey" ? "Key 24h" : data.type;
          document.getElementById("r-expiry").textContent   = data.expiry;
          document.getElementById("r-timeleft").textContent = data.timeLeft;
          result.style.display = "block";
        } else {
          showError("❌ " + (data.message || "Key không hợp lệ!"));
        }
      } catch (e) {
        showError("❌ Không kết nối được server. Thử lại!");
      }
    }

    function copyKey() {
      const key = document.getElementById("r-key").textContent;
      navigator.clipboard.writeText(key).then(() => {
        const cb = document.querySelector(".copy-btn");
        cb.textContent = "✅ Đã sao chép!";
        setTimeout(() => { cb.textContent = "📋 Sao chép Key"; }, 2000);
      });
    }

    loadKey();
  </script>
</body>
</html>
